# 环境变量配置示例
# 复制此文件为 .env.development 或 .env.production

# 开发环境和生产环境都使用相对路径
# 通过 Nginx 代理转发到后端 API
# 这样避免 CORS 跨域问题

VUE_APP_BASE_API=/api
VUE_APP_WS_URL=/im

# Nginx 配置需要包括：
# location /api/ {
#     proxy_pass https://jlapi.relaynet.io/;
# }
# location /im/ {
#     proxy_pass https://jlws.relaynet.io/;
# }
